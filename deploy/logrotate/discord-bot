# Logrotate configuration for Discord AI Bot
# Place in /etc/logrotate.d/discord-bot or /etc/logrotate.conf

/opt/discord-bot-ai/logs/*.log {
    daily
    missingok
    rotate 30
    compress
    delaycompress
    notifempty
    create 0640 discordbot discordbot
    sharedscripts
    postrotate
        # Send SIGUSR1 to application to reopen log files (if supported)
        # kill -SIGUSR1 `cat /var/run/discord-bot.pid 2>/dev/null` 2>/dev/null || true
        # Or restart supervisor/systemd service
        # For Docker: docker restart discord-bot-ai
        :
    endscript
}

# Also rotate systemd logs if using journal
# See: journalctl --vacuum-time=7d for automatic cleanup
